{
  "name": "clawgame",
  "version": "0.20.4",
  "private": true,
  "description": "AI-first web game engine and editor",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"pnpm --filter @clawgame/web dev\" \"pnpm --filter @clawgame/api dev\"",
    "dev:web": "pnpm --filter @clawgame/web dev",
    "dev:api": "pnpm --filter @clawgame/api dev",
    "build": "pnpm --filter @clawgame/shared build && pnpm --filter @clawgame/engine build && pnpm -r build",
    "typecheck": "pnpm run -r typecheck",
    "test": "pnpm run -r test && pnpm run typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "bash -c 'pnpm run typecheck'"
  },
  "keywords": [
    "game-engine",
    "ai",
    "openclaw",
    "2d",
    "web"
  ],
  "author": "Peter",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "node-fetch": "3.3.2"
  }
}
