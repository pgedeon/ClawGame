    {
      "id": "elder-mira",
      "npcName": "Elder Mira",
      "npcPortrait": "🧙",
      "startLineId": "greeting",
      "lines": {
        "greeting": {
          "id": "greeting",
          "speaker": "Elder Mira",
          "portrait": "🧙",
          "text": "Welcome, young Rune Walker. The darkness grows stronger... Will you help us?",
          "choices": [
            { "text": "I'll help. What must I do?", "next": "accept" },
            { "text": "Tell me more first.", "next": "info" },
            { "text": "Not right now.", "next": "decline" }
          ]
        },
        "info": {
          "id": "info",
          "speaker": "Elder Mira",
          "portrait": "🧙",
          "text": "Slimes have infested the arena. Defeat 3 of them and the path to the Shadow Rune will open.",
          "choices": [
            { "text": "I'll do it!", "next": "accept" },
            { "text": "Sounds dangerous. Maybe later.", "next": "decline" }
          ]
        },
        "accept": {
          "id": "accept",
          "speaker": "Elder Mira",
          "portrait": "🧙",
          "text": "Excellent! Go forth and defeat 3 Slimes. I'll reward you handsomely. Press J to track your quest!",
          "next": null,
          "effect": { "type": "startQuest", "payload": { "questId": "slime-slayer" } }
        },
        "decline": {
          "id": "decline",
          "speaker": "Elder Mira",
          "portrait": "🧙",
          "text": "I understand. Return when you're ready, Rune Walker.",
          "next": null
        },
        "quest_complete": {
          "id": "quest_complete",
          "speaker": "Elder Mira",
          "portrait": "🧙",
          "text": "You've done it! The slimes are vanquished. Take this healing blessing as my thanks.",
