/**
 * Image Style Preset Service — M11: Generative Media Forge
 *
 * Curated generation profiles tuned for specific asset roles.
 * Each preset defines prompt templates, dimensions, style, and palette overrides
 * so users can quickly generate character/enemy/prop/background assets
 * without hand-tuning every parameter.
 */

import { FastifyBaseLogger } from 'fastify';
import { AIImageGenerationService } from './aiImageGenerationService';
import { 
  AssetRole, 
  roleToType,
  ArtStyle,
  AspectRatio,
  GenerationQuality,
  GenerationModel 
} from '../types/assetTypes';

// ── Types ──

export interface StylePreset {
  id: string;
  name: string;
  role: AssetRole;
  artStyle: ArtStyle;
  promptTemplate: string;
  dimensions: {
    width: number;
    height: number;
    aspectRatio: AspectRatio;
  };
  palette: {
    primary: string;
    secondary: string;
    accent: string;
    background: string;
  };
  quality: GenerationQuality;
  model: GenerationModel;
  tags: string[];
  description: string;
  examples?: string[];
}

export interface PresetGenerationRequest {
  projectId: string;
  presetId: string;
  description: string;
  artStyle?: ArtStyle;
  width?: number;
  height?: number;
  count?: number;
}

export interface PresetGenerationResult {
  preset: StylePreset;
  assets: Array<{
    id: string;
    content: string;
    format: string;
    width: number;
    height: number;
    generationTime: number;
  }>;
  metadata: {
    total: number;
    successful: number;
    failed: number;
    processingTime: number;
  };
}

// ── Service Implementation ──

export class ImageStylePresetService {
  private aiService: AIImageGenerationService;
  private presets: StylePreset[] = [];

  constructor(logger: FastifyBaseLogger) {
    this.aiService = new AIImageGenerationService(null as any, logger);
    this.initializePresets();
  }

  // ── Public Methods ──

  /** Get all available presets */
  getAllPresets(): StylePreset[] {
    return this.presets;
  }

  /** Get a specific preset by ID */
  getPreset(presetId: string): StylePreset | undefined {
    return this.presets.find(preset => preset.id === presetId);
  }

  /** List all available presets (for API compatibility) */
  listPresets(): StylePreset[] {
    return this.getAllPresets();
  }

  /** List all available roles (for API compatibility) */
  listRoles(): AssetRole[] {
    return [
      AssetRole.CHARACTER,
      AssetRole.ENEMY,
      AssetRole.NPC,
      AssetRole.PROP,
      AssetRole.CHEST,
      AssetRole.BACKGROUND,
      AssetRole.TILESET,
      AssetRole.ICON,
      AssetRole.UI_ELEMENT,
      AssetRole.EFFECT,
    ];
  }

  /** Generate assets from a preset */
  async generateFromPreset(request: PresetGenerationRequest): Promise<PresetGenerationResult> {
    const preset = this.getPreset(request.presetId);
    if (!preset) {
      throw new Error(`Preset not found: ${request.presetId}`);
    }

    const startTime = Date.now();
    const results: PresetGenerationResult['assets'] = [];
    let successful = 0;
    let failed = 0;

    // Generate multiple assets if count is specified
    const count = request.count || 1;
    const descriptions = this.generateVariations(request.description, count);

    for (let i = 0; i < descriptions.length; i++) {
      try {
        const variantPrompt = this.buildVariantPrompt(descriptions[i], preset);
        const generationRequest: any = {
          projectId: request.projectId,
          type: roleToType(preset.role),
          prompt: variantPrompt,
          style: preset.artStyle,
          width: request.width || preset.dimensions.width,
          height: request.height || preset.dimensions.height,
          format: 'svg',
          quality: preset.quality,
          model: preset.model,
        };

        const result = await this.aiService.generateAsset(generationRequest);
        
        results.push({
          id: `preset-${preset.id}-${Date.now()}-${i}`,
          content: result.content,
          format: result.metadata.format,
          width: result.metadata.width,
          height: result.metadata.height,
          generationTime: result.metadata.generationTime,
        });

        successful++;
      } catch (error) {
        if (this.aiService['logger']) {
          this.aiService['logger'].error(`Failed to generate asset ${i} from preset ${preset.id}:`, error);
        }
        failed++;
      }
    }

    return {
      preset,
      assets: results,
      metadata: {
        total: count,
        successful,
        failed,
        processingTime: Date.now() - startTime,
      },
    };
  }

