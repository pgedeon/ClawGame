  // ── Prompt Generation Helpers ──

  private generateVariations(description: string, count: number): string[] {
    const variations: string[] = [];
    const base = description.toLowerCase();
    
    // Generate different variations using synonyms and contexts
    const contexts = [
      'video game',
      'pixel art',
      'cartoon character',
      'fantasy game',
      'rpg game',
      'platformer game',
      'adventure game'
    ];
    
    const adjectives = [
      'detailed',
      'high quality',
      'professional',
      'stylized',
      'character design',
      'game asset',
      'sprite art'
    ];
    
    for (let i = 0; i < count; i++) {
      let variation = base;
      
      // Add context if not already present
      if (!contexts.some(ctx => base.includes(ctx))) {
        variation += `, ${contexts[i % contexts.length]}`;
      }
      
      // Add adjectives
      variation += `, ${adjectives[i % adjectives.length]}`;
      
      variations.push(variation);
    }
    
    return variations;
  }

  private buildVariantPrompt(description: string, preset: StylePreset): string {
    let prompt = `${preset.promptTemplate}, ${description}`;
    
    // Add preset art style
    prompt += `, ${preset.artStyle} style`;
    
    // Add quality based on preset
    switch (preset.quality) {
      case GenerationQuality.HIGH:
        prompt += ', highly detailed, professional quality';
        break;
      case GenerationQuality.STANDARD:
        prompt += ', good quality, suitable for games';
        break;
      case GenerationQuality.DRAFT:
        prompt += ', draft concept, quick prototype';
        break;
    }
    
    return prompt;
  }
}